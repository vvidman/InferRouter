## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# VisualStudio
.vs

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# dotenv environment variables file
.env

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# =============================================================================
# SECRETS — never commit credentials or API keys
# =============================================================================

# Live secrets directory (copy of secrets.example/ with real keys)
secrets/

# Any stray key/token files anywhere in the tree
*.key
*.apikey
*.secret
*.token
*.credentials

# Local overrides that may contain secrets
appsettings.Local.json
appsettings.*.Local.json

# =============================================================================
# DOCKER
# =============================================================================

# Docker override files (often contain local bind mounts or dev credentials)
docker-compose.override.yml
docker-compose.*.override.yml

# Docker build context temporary files
.dockerignore.local

# Volume data directories if mounted locally during development
docker/volumes/
docker/data/

# =============================================================================
# INFERROUTER RUNTIME ARTIFACTS
# =============================================================================

# Operation log (JSONL — can grow large, not source)
*.jsonl

# GGUF model files (large binary, user-provided)
*.gguf
*.bin
models/

# =============================================================================
# IDE / OS
# =============================================================================

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
